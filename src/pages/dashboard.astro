---
import Layout from '../layouts/Layout.astro';
import AddGameForm from '../components/AddGameForm.astro';
import EditGamePanel from '../components/EditGamePanel.astro';
import DeleteGamePanel from '../components/DeleteGamePanel.astro';
import ViewGamesPanel from '../components/ViewGamesPanel.astro';
import StatsCards from '../components/StatsCards.astro';
import ActionButtons from '../components/ActionButtons.astro';
---

<Layout title="Administración de Catálogo">
  <main class="min-h-screen bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 px-4 py-12">
    <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-2"></div>
    
    <div id="auth-container" class="max-w-6xl mx-auto">
      <div id="login-section" class="max-w-2xl mx-auto bg-linear-to-br from-slate-800 to-slate-900 p-10 rounded-2xl border border-slate-700/50 shadow-2xl backdrop-blur">
        <div class="mb-8 text-center">
          <h1 class="text-4xl font-bold bg-linear-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent mb-2">3DS Catalogue</h1>
          <h2 class="text-xl font-semibold text-cyan-300">Panel de Administración</h2>
        </div>
        
        <form id="login-form" class="space-y-5" onsubmit="return false;">
          <div class="space-y-2">
            <label class="text-sm font-semibold text-slate-300">Correo Electrónico</label>
            <input type="email" name="email" placeholder="admin@example.com" class="w-full px-4 py-3 rounded-lg bg-slate-900/50 border border-slate-600 focus:border-cyan-400 focus:bg-slate-900 outline-none transition placeholder-slate-500" required />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-semibold text-slate-300">Contraseña</label>
            <input type="password" name="password" placeholder="••••••••" class="w-full px-4 py-3 rounded-lg bg-slate-900/50 border border-slate-600 focus:border-cyan-400 focus:bg-slate-900 outline-none transition" required />
          </div>
          <button type="submit" class="w-full bg-linear-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-bold py-3 rounded-lg transition transform hover:scale-105 shadow-lg">
            Acceder al Panel
          </button>
        </form>
      </div>

      <div id="admin-section" class="hidden space-y-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <h1 class="text-4xl font-bold bg-linear-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent">Gestionar Catálogo</h1>
            <p class="mt-2 text-sm text-slate-400">Selecciona una acción para administrar los registros de Supabase.</p>
          </div>
          <button id="logout-btn" class="px-4 py-2 rounded-lg bg-red-500/20 border border-red-500/50 text-red-300 hover:bg-red-500/40 transition font-medium text-sm">
            Cerrar Sesión
          </button>
        </div>

        <StatsCards />

        <ActionButtons />

        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)]">
          <AddGameForm />

          <div class="space-y-6">
            <EditGamePanel />
            <DeleteGamePanel />
            <ViewGamesPanel />
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import { loadGames, showToast } from '../lib/dashboardUtils';

  let setupController: AbortController | null = null;
  let authSubscription: { unsubscribe: () => void } | null = null;

  const toggleSections = (isLoggedIn: boolean) => {
    const loginSection = document.getElementById('login-section');
    const adminSection = document.getElementById('admin-section');

    loginSection?.classList.toggle('hidden', isLoggedIn);
    adminSection?.classList.toggle('hidden', !isLoggedIn);
  };

  // Función principal para configurar el dashboard
  const setupAdmin = async () => {
    setupController?.abort();
    setupController = new AbortController();
    const { signal } = setupController;

    authSubscription?.unsubscribe();
    authSubscription = null;

    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const logoutBtn = document.getElementById('logout-btn');

    if (!loginForm) {
      return;
    }

    const pageViewsRaw = Number(localStorage.getItem('dashboard_page_views') ?? '0');
    localStorage.setItem('dashboard_page_views', String(pageViewsRaw + 1));

    // 1. Verificar sesión inmediatamente
    const { data: { session } } = await supabase.auth.getSession();
    if (signal.aborted) return;

    toggleSections(!!session);

    if (session) {
      try {
        const games = await loadGames();
        window.dispatchEvent(new CustomEvent('gamesUpdated', { detail: { games } }));
      } catch (err) {
        showToast(`Error al cargar juegos: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
      }
    }

    // Mantener UI sincronizada con cambios de sesión
    const { data: authListener } = supabase.auth.onAuthStateChange(async (_event, activeSession) => {
      if (signal.aborted) return;
      toggleSections(!!activeSession);

      if (activeSession) {
        try {
          const games = await loadGames();
          window.dispatchEvent(new CustomEvent('gamesUpdated', { detail: { games } }));
        } catch (err) {
          showToast(`Error al cargar juegos: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
        }
      }
    });
    authSubscription = authListener.subscription;

    // 2. Manejar Login
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(loginForm);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      const submitButton = loginForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitButton.disabled = true;
      submitButton.textContent = 'Accediendo...';

      try {
        const { data, error } = await supabase.auth.signInWithPassword({
          email,
          password,
        });

        if (error) {
          showToast("Error: " + error.message, 'error');
        } else {
          showToast("¡Bienvenido! Sesión iniciada correctamente", 'success');
          toggleSections(!!data.session);
          if (data.session) {
            try {
              const games = await loadGames();
              window.dispatchEvent(new CustomEvent('gamesUpdated', { detail: { games } }));
            } catch (err) {
              showToast(`Error al cargar juegos: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
            }
          }
          loginForm.reset();
        }
      } catch (err) {
        showToast(`Error: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Acceder al Panel';
      }
    }, { signal });

    window.addEventListener('request-games-refresh', async () => {
      if (signal.aborted) return;

      try {
        const games = await loadGames();
        window.dispatchEvent(new CustomEvent('gamesUpdated', { detail: { games } }));
      } catch (err) {
        showToast(`Error al cargar juegos: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
      }
    }, { signal });

    // 3. Logout
    logoutBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      const btn = e.target as HTMLButtonElement;
      btn.disabled = true;
      
      try {
        await supabase.auth.signOut();
        showToast("Sesión cerrada", 'info');
        setTimeout(() => window.location.reload(), 500);
      } catch (err) {
        showToast(`Error al cerrar sesión: ${err instanceof Error ? err.message : 'Error desconocido'}`, 'error');
        btn.disabled = false;
      }
    }, { signal });
  };

  // Correr al cargar el DOM
  document.addEventListener('DOMContentLoaded', setupAdmin);
  
  // Si usas ViewTransitions de Astro
  document.addEventListener('astro:page-load', setupAdmin);
  
  // Ejecución inmediata por si el DOM ya está listo
  setupAdmin();
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  .animate-in {
    animation: fadeIn 0.3s ease-out;
  }

  .animate-out {
    animation: fadeOut 0.3s ease-out;
  }

  .panel-card {
    min-height: 100%;
  }

  .game-select-list {
    max-height: 13.5rem;
    overflow-y: auto;
    padding: 0.5rem;
  }
</style>