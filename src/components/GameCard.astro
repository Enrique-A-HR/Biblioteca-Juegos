---
interface Props {
  title: string;
  platform: string; // '3DS' o 'DS'
  coverUrl: string;
  targetUrl: string;
  size: string;
  language: string;
  hasHshop?: boolean; // Badge opcional de Hshop
}

const { title, platform, coverUrl, targetUrl, size, language, hasHshop = false } = Astro.props;

// Normalizamos la plataforma para el color del badge
const is3DS = platform.toLowerCase() === '3ds';
const isDS = platform.toLowerCase() === 'ds';
---

<div class="group perspective-1000 w-full">
  <div class="relative transition-all duration-500 ease-out transform-style-3d group-hover:rotate-x-8 group-hover:rotate-y-[-8deg] group-hover:scale-[1.05] group-hover:shadow-2xl" style="transform-origin: center;">
    
    <a href={targetUrl} target="_blank" rel="noopener noreferrer" class="block relative overflow-hidden rounded-xl bg-gradient-to-b from-slate-700 to-slate-900 shadow-2xl border border-slate-700/50 transform-style-3d group-hover:border-cyan-400/30 transition-colors duration-500">
      {isDS && (
        <div class="absolute top-0 left-0 right-0 z-20 px-3 pt-3 pointer-events-none">
              <div class="mx-auto flex w-fit items-center gap-1.5 rounded-full border border-cyan-400/40 bg-blue-500/90 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                  <line x1="12" y1="9" x2="12" y2="13" />
                  <circle cx="12" cy="16" r="1" />
                </svg>
                Requires Twilight Menu ++
          </div>
        </div>
      )}
      
      <div class="aspect-square overflow-hidden relative bg-white">
        <img 
          src={coverUrl} 
          alt={`Cover for ${title}`}
          class="w-full h-full object-contain transition-all duration-700 group-hover:scale-105 opacity-85 group-hover:opacity-100"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-white/0 via-white/0 to-black/20 group-hover:to-black/40 transition-all duration-700"></div>
      </div>

      <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-[#0f172a]/50 to-transparent flex flex-col justify-end p-4 translate-z-20 transition-all duration-500 group-hover:via-[#0f172a]/30 group-hover:from-[#0f172a]/95">
        
        <div class="flex items-center gap-2 mb-2">
          <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider ${is3DS ? 'bg-red-500 text-white shadow-[0_0_10px_rgba(239,68,68,0.5)]' : 'bg-blue-500 text-white shadow-[0_0_10px_rgba(59,130,246,0.5)]'}`}>
            {platform}
          </span>
          {hasHshop && (
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider bg-lime-500 text-white shadow-[0_0_10px_rgba(168,85,247,0.5)]">
              Hshop
            </span>
          )}
        </div>

        <h2 class="text-white font-bold text-xl leading-tight drop-shadow-md line-clamp-2">
          {title}
        </h2>

        <div class="flex justify-between items-center mt-3 pt-3 border-t border-white/10 text-[11px] font-medium text-slate-300">
          <div class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {size}
          </div>
          <div class="flex items-center gap-1 uppercase tracking-tighter">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {language}
          </div>
        </div>
      </div>

      <div class="absolute inset-0 opacity-0 group-hover:opacity-30 bg-gradient-to-tr from-transparent via-white/40 to-transparent -translate-x-full group-hover:translate-x-full transition-all duration-1000 pointer-events-none"></div>
      
      <div class="absolute top-0 left-0 right-0 bottom-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none bg-gradient-radial from-cyan-400/20 via-transparent to-transparent"></div>
      
    </a>
  </div>
</div>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  .translate-z-20 {
    /* Esto eleva el texto un poco por encima de la imagen en el espacio 3D */
    transform: translateZ(20px);
  }
  .bg-gradient-radial {
    background: radial-gradient(circle at center, var(--tw-gradient-stops));
  }
  @supports not (background: radial-gradient(circle, red, blue)) {
    .bg-gradient-radial {
      background: radial-gradient(circle, currentColor, transparent);
    }
  }
</style>